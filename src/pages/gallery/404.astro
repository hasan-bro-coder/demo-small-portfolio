---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../data.ts';
const entries = await getCollection('gallery');
---
<Layout
  title={`Gallery — ${siteConfig.name}`}
  description={`Photography gallery by ${siteConfig.author.name}. Explore ${entries.length} collections of portraiture, landscape, and architectural photography.`}
>
  <div class="p-8 md:p-12">
    <h1 class="font-display text-4xl font-medium text-(--text) mb-10">Gallery</h1>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {entries.map(e => {
        const slug  = e.id.replace(/\.json$/, '');
        const cover = Array.isArray(e.data.images) ? e.data.images[0] : e.data.images;
        return (
          <a href={`/gallery/${slug}`} class="group relative overflow-hidden aspect-square block">
            <img src={cover} alt={e.data.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 grayscale" />
            <div class="absolute inset-x-0 bottom-0 p-4 bg-linear-to-t from-black/70 to-transparent">
              <p class="font-display text-xl font-medium text-white">{e.data.title}</p>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
