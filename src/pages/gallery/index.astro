---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const entries = await getCollection('gallery');
---
<Layout title="Gallery — Alex Mercer">
  <div class="p-8 md:p-12">
    <h1 class="font-display text-4xl font-light text-[var(--text)] mb-10">Gallery</h1>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {entries.map(e => {
        const slug  = e.id.replace(/\.json$/, '');
        const cover = Array.isArray(e.data.images) ? e.data.images[0] : e.data.images;
        return (
          <a href={`/gallery/${slug}`} class="group relative overflow-hidden aspect-square block">
            <img src={cover + '&w=600&q=80&auto=format'} alt={e.data.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 grayscale" />
            <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/70 to-transparent">
              <p class="font-display text-xl font-light text-white">{e.data.title}</p>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
