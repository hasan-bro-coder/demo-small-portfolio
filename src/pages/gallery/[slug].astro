---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('gallery');
  return entries.map(e => ({
    params: { slug: e.id.replace(/\.json$/, '') },
    props:  { entry: e },
  }));
}
const { entry } = Astro.props;
const { title, detail } = entry.data;
const images = Array.isArray(entry.data.images) ? entry.data.images : [entry.data.images];
---
<Layout title={`${title} — Alex Mercer`}>
  <div class="p-8 md:p-12">
    <header class="mb-8 border-b border-[var(--border)] pb-6">
      <h1 class="font-display text-4xl md:text-5xl font-light text-[var(--text)]">{title}</h1>
      {detail && <p class="text-sm text-[var(--text-2)] mt-2">{detail}</p>}
    </header>

    <div class="gallery-grid">
      {images.map((src, i) => (
        <div class="gallery-item" data-src={src} data-i={i}>
          <img src={src + '&auto=format&q=82&w=900'} alt={`${title} ${i+1}`} loading={i < 4 ? 'eager' : 'lazy'} />
        </div>
      ))}
    </div>
  </div>

  <!-- Lightbox -->
  <div id="lb" class="lightbox">
    <button id="lb-close" class="absolute top-5 right-5 text-white/50 hover:text-white text-2xl leading-none z-10" aria-label="Close">✕</button>
    <button id="lb-prev"  class="absolute left-4  top-1/2 -translate-y-1/2 text-white/50 hover:text-white z-10 text-3xl leading-none">‹</button>
    <button id="lb-next"  class="absolute right-4 top-1/2 -translate-y-1/2 text-white/50 hover:text-white z-10 text-3xl leading-none">›</button>
    <img id="lb-img" src="" alt="" />
  </div>
</Layout>

<script>
  import gsap from 'gsap';
  gsap.from('.gallery-item', { opacity: 0, duration: 0.5, stagger: 0.06, ease: 'power2.out', delay: 0.2 });

  const items = Array.from(document.querySelectorAll<HTMLElement>('.gallery-item'));
  const lb    = document.getElementById('lb')!;
  const img   = document.getElementById('lb-img') as HTMLImageElement;
  let   cur   = 0;

  const open  = (i: number) => {
    cur = i;
    img.src = items[i].dataset.src + '&auto=format&q=90&w=1800';
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  };
  const close = () => { lb.classList.remove('open'); document.body.style.overflow = ''; };

  items.forEach((el, i) => el.addEventListener('click', () => open(i)));
  document.getElementById('lb-close')?.addEventListener('click', close);
  document.getElementById('lb-prev')?.addEventListener('click', e => { e.stopPropagation(); open((cur - 1 + items.length) % items.length); });
  document.getElementById('lb-next')?.addEventListener('click', e => { e.stopPropagation(); open((cur + 1) % items.length); });
  lb.addEventListener('click', e => { if (e.target === lb || e.target === img) close(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  open((cur - 1 + items.length) % items.length);
    if (e.key === 'ArrowRight') open((cur + 1) % items.length);
  });
</script>
