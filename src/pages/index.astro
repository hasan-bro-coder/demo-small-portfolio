---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const entries = await getCollection('gallery');
---
<Layout title="Alex Mercer">
  <div class="p-8 md:p-12">
    <header class="mb-14">
      <h1 class="font-display text-5xl md:text-6xl font-light text-[var(--text)] leading-tight">
        Alex Mercer
      </h1>
      <p class="text-sm text-[var(--text-2)] mt-3 max-w-xs">
        Photography. New York.
      </p>
    </header>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {entries.map(e => {
        const slug  = e.id.replace(/\.json$/, '');
        const cover = Array.isArray(e.data.images) ? e.data.images[0] : e.data.images;
        return (
          <a href={`/gallery/${slug}`} class="group relative overflow-hidden aspect-[3/4] block">
            <img src={cover + '&w=600&q=80&auto=format'} alt={e.data.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 grayscale" />
            <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/60 to-transparent">
              <p class="font-display text-lg font-light text-white">{e.data.title}</p>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>

<script>
  import gsap from 'gsap';
  gsap.from('h1', { opacity: 0, y: 16, duration: 0.8, ease: 'power3.out', delay: 0.1 });
  gsap.from('header p', { opacity: 0, y: 8, duration: 0.6, ease: 'power3.out', delay: 0.3 });
  gsap.from('.grid a', { opacity: 0, duration: 0.6, stagger: 0.08, ease: 'power2.out', delay: 0.4 });
</script>
