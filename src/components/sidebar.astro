---
import { getCollection } from 'astro:content';
const entries  = await getCollection('gallery');
const cats     = entries.map(e => ({ slug: e.id.replace(/\.json$/, ''), title: e.data.title }));
const path     = Astro.url.pathname;
---

<!-- Desktop sidebar -->
<aside class="sidebar">
  <div class="px-6 pt-8 pb-6 border-b border-(--border)">
    <a href="/" class="block">
      <span class="font-colitezserif text-xl font-medium tracking-widest text-(--text) uppercase">Alex Mercer</span>
      <span class="block text-[10px] tracking-[0.2em] text-(--text-3) uppercase mt-0.5">Photography</span>
    </a>
  </div>

  <nav class="flex-1 overflow-y-auto py-5 px-4">
    <!-- Gallery toggle -->
    <button id="g-toggle" class="w-full flex items-center justify-between px-3 py-2 text-[10px] tracking-[0.2em] uppercase text-[var(--text-3)] hover:text-[var(--text-2)] transition-colors">
      <span>Gallery</span>
      <svg id="g-chevron" class="w-2.5 h-2.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
    <ul id="g-list" class="mt-0.5 space-y-px overflow-hidden">
      {cats.map(c => (
        <li>
          <a href={`/gallery/${c.slug}`}
            class:list={['nav-link relative flex items-center pl-5 pr-3 py-1.5 text-sm text-[var(--text-2)] hover:text-[var(--text)] rounded-sm hover:bg-[var(--border)] transition-all duration-150',
              { 'active': path.startsWith(`/gallery/${c.slug}`) }]}>
            {c.title}
          </a>
        </li>
      ))}
    </ul>

    <div class="my-4 border-t border-(--border)"></div>

    <ul class="space-y-px">
      {[['about','About'],['contact','Contact']].map(([slug,label]) => (
        <li>
          <a href={`/${slug}`}
            class:list={['nav-link relative flex items-center pl-5 pr-3 py-1.5 text-sm text-[var(--text-2)] hover:text-[var(--text)] rounded-sm hover:bg-[var(--border)] transition-all duration-150',
              { 'active': path === `/${slug}` || path === `/${slug}/` }]}>
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<!-- Mobile top bar -->
<header class="md:hidden fixed top-0 left-0 right-0 h-14 bg-(--bg-2) border-b border-(--border) flex items-center justify-between px-5" style="z-index:60">
  <a href="/" class="font-colitezserif text-base tracking-widest text-(--text) uppercase">Alex Mercer</a>
  <button id="m-btn" class="relative w-5 h-4 text-(--text-2)" aria-label="Menu">
    <span id="l1" class="absolute left-0 top-0   block w-5 h-px bg-current transition-all duration-300 origin-center"></span>
    <span id="l2" class="absolute left-0 top-1.5 block w-5 h-px bg-current transition-all duration-300 origin-center"></span>
    <span id="l3" class="absolute left-0 top-3   block w-5 h-px bg-current transition-all duration-300 origin-center"></span>
  </button>
</header>

<!-- Mobile overlay -->
<div id="m-overlay" class="md:hidden fixed inset-0 bg-black/70 pointer-events-none opacity-0" style="top:56px;z-index:55;transition:opacity 0.3s ease"></div>

<!-- Mobile drawer (slides from right) -->
<nav id="m-nav" class="md:hidden fixed right-0 bottom-0 w-64 bg-(--bg-2) border-l border-[var(--border)] flex flex-col overflow-y-auto pointer-events-none"
  style="top:56px;z-index:56;transform:translateX(100%);transition:transform 0.35s cubic-bezier(0.16,1,0.3,1)">
  <div class="px-5 pt-5 pb-8 flex-1">
    <p class="text-[10px]  tracking-[0.2em] uppercase text-(--text-3) mb-2">Gallery</p>
    <ul class="space-y-px mb-5">
      {cats.map(c => (
        <li><a href={`/gallery/${c.slug}`} class="m-link block py-2 px-3 text-sm text-[var(--text-2)] hover:text-[var(--text)] hover:bg-[var(--border)] rounded-sm transition-all">{c.title}</a></li>
      ))}
    </ul>
    <div class="border-t border-(--border) pt-4 space-y-px">
      <a href="/about"   class="m-link block py-2 px-3 text-sm text-(--text-2) hover:text-[var(--text)] hover:bg-[var(--border)] rounded-sm transition-all">About</a>
      <a href="/contact" class="m-link block py-2 px-3 text-sm text-(--text-2) hover:text-[var(--text)] hover:bg-[var(--border)] rounded-sm transition-all">Contact</a>
    </div>
  </div>
</nav>

<script>
  // Gallery accordion
  const gList    = document.getElementById('g-list')!;
  const gChevron = document.getElementById('g-chevron')!;
  let   gOpen    = true;
  gList.style.cssText += 'overflow:hidden;transition:max-height 0.3s ease;';
  gList.style.maxHeight = gList.scrollHeight + 'px';
  document.getElementById('g-toggle')?.addEventListener('click', () => {
    gOpen = !gOpen;
    gList.style.maxHeight    = gOpen ? gList.scrollHeight + 'px' : '0';
    gChevron.style.transform = gOpen ? '' : 'rotate(-90deg)';
  });

  // Mobile drawer
  const overlay = document.getElementById('m-overlay')!;
  const nav     = document.getElementById('m-nav')!;
  const l1 = document.getElementById('l1')!;
  const l2 = document.getElementById('l2')!;
  const l3 = document.getElementById('l3')!;
  let open = false;

  const set = (v: boolean) => {
    open = v;
    nav.style.transform      = v ? 'translateX(0)' : 'translateX(100%)';
    nav.style.pointerEvents  = v ? 'all' : 'none';
    overlay.style.opacity    = v ? '1' : '0';
    overlay.style.pointerEvents = v ? 'all' : 'none';
    l1.style.transform = v ? 'translateY(6px) rotate(45deg)'  : '';
    l2.style.opacity   = v ? '0' : '1';
    l3.style.transform = v ? 'translateY(-6px) rotate(-45deg)' : '';
    document.body.style.overflow = v ? 'hidden' : '';
  };

  document.getElementById('m-btn')?.addEventListener('click', () => set(!open));
  overlay.addEventListener('click', () => set(false));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') set(false); });
  document.querySelectorAll('.m-link').forEach(l => l.addEventListener('click', () => set(false)));
</script>
